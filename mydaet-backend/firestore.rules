/*
 *Update 03-05
 * Firestore rules for the revised 5-role RBAC model.
 * Office Admin is distinct from municipal Admin.
 * Rules here intentionally preserve legacy claim aliases while enforcing the new role split.
 * This pass keeps report reads and timelines aligned with the SOP-driven server workflow.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** -------------------------
     * Helpers
     * Revised 5-role RBAC model:
     * - office_admin is distinct from admin
     * - admin is municipal-wide
     * - moderator and office_admin require office scope
     * Rules must stay aligned with Cloud Functions while preserving legacy claim aliases during migration.
     * ------------------------- */
    function signedIn() {
      return request.auth != null;
    }

    function signedInUser() {
      return signedIn();
    }

    function role() {
      // Security baseline: rely on canonical role claim values issued by
      // backend/admin claim management. Unknown/missing values fall back to
      // resident (least privilege).
      return signedIn()
        && ("role" in request.auth.token)
        && request.auth.token.role is string
        && request.auth.token.role in ["resident", "moderator", "office_admin", "admin", "super_admin"]
        ? request.auth.token.role
        : "resident";
    }

    function officeId() {
      return (request.auth != null && ("officeId" in request.auth.token) && request.auth.token.officeId != null)
        ? request.auth.token.officeId
        : null;
    }

    function officeName() {
      return (request.auth != null && ("officeName" in request.auth.token) && request.auth.token.officeName != null)
        ? request.auth.token.officeName
        : null;
    }

    function isActive() {
      return (request.auth != null && ("isActive" in request.auth.token) && request.auth.token.isActive != null)
        ? request.auth.token.isActive
        : true;
    }

    function activeUser() {
      return signedIn() && isActive();
    }

    function isSuperAdmin() {
      return role() == "super_admin";
    }

    function isOfficeAdmin() {
      return role() == "office_admin";
    }

    function isMunicipalAdmin() {
      return role() == "admin";
    }

    function isModerator() {
      return role() == "moderator";
    }

    function isStaff() {
      return isSuperAdmin()
        || isMunicipalAdmin()
        || (
          (isOfficeAdmin() || isModerator())
          && officeId() != null
          && officeId() != ""
        );
    }

    function civilRegistryOfficeIds() {
      return [
        "OFFICE_OF_THE_CIVIL_REGISTRAR",
        "MUNICIPAL_LOCAL_CIVIL_REGISTRY_OFFICE",
        "MUNICIPAL_CIVIL_REGISTRY_OFFICE",
        "CIVIL_REGISTRY_OFFICE",
        "MLCRO"
      ];
    }

    function civilRegistryOfficeTag(value) {
      return value != null && (
        value in civilRegistryOfficeIds()
        || (value is string && value.matches(".*[cC][iI][vV][iI][lL].*[rR][eE][gG][iI][sS][tT][rR].*"))
        || (value is string && value.matches(".*[mM][lL][cC][rR][oO].*"))
      );
    }

    function canAccessCivilRegistry() {
      return signedInUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || (
          isStaff()
          && (
            civilRegistryOfficeTag(officeId())
            || civilRegistryOfficeTag(officeName())
          )
        )
      );
    }

    function hasOfficeId(data) {
      return data.keys().hasAny(["officeId"]) && data.officeId != null && data.officeId != "";
    }

    function hasNonEmptyString(data, field) {
      return data.keys().hasAny([field]) && data[field] is string && data[field] != "";
    }

    function stringWithin(value, max) {
      return !(value is string) || value.size() <= max;
    }

    function mapValueOrNull(data, field) {
      return data.keys().hasAny([field]) ? data[field] : null;
    }

    function unchangedOrWithin(field, max) {
      // Use changedKeys() to skip untouched fields, then safely read the value
      // with a key-presence guard.
      return !request.resource.data.diff(resource.data).changedKeys().hasAny([field])
        || stringWithin(mapValueOrNull(request.resource.data, field), max);
    }

    function sameField(field) {
      // Compare field values with key-existence guards so missing fields on either
      // side are treated as null and do not trigger "undefined property" errors.
      return mapValueOrNull(request.resource.data, field) == mapValueOrNull(resource.data, field);
    }

    function officeAllowed(data) {
      return isSuperAdmin()
        || isMunicipalAdmin()
        || !hasOfficeId(data)
        || (officeId() != null && data.officeId == officeId())
    }

    function reportInOfficeScope(data) {
      return officeId() != null
        && (
          data.officeId == officeId()
          || data.currentOfficeId == officeId()
          || data.assignedOfficeId == officeId()
          || data.assignedToUid == request.auth.uid
        );
    }

    function reportStaffReadAllowed(data) {
      return signedInUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || ((isOfficeAdmin() || isModerator()) && reportInOfficeScope(data))
      );
    }

    function reportSubDocReadAllowed(data) {
      return reportStaffReadAllowed(data)
        || (data.createdByUid != null && data.createdByUid == request.auth.uid);
    }

    function reportSubDocLegacyStaffRead(data) {
      // Legacy timeline/history rows may not include scope mirror fields yet.
      // Allow staff-only reads for those legacy rows until backfill is complete.
      return isStaff()
        && !data.keys().hasAny([
          "createdByUid",
          "officeId",
          "currentOfficeId",
          "assignedOfficeId",
          "assignedToUid"
        ]);
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAllowedUserSelfUpdate() {
      return request.resource.data.diff(resource.data).changedKeys()
        .hasOnly(["displayName", "photoUrl", "phone", "updatedAt"]);
    }

    function hasNoPrivilegedUserFieldChanges() {
      return !request.resource.data.diff(resource.data).changedKeys()
        .hasAny(["role", "status", "uid", "email", "createdAt", "officeId", "officeName", "isActive"]);
    }

    function dtsOfficeAllowed(data) {
      return isSuperAdmin()
        || isMunicipalAdmin()
        || (
          isStaff()
          && (
            (officeId() != null && data.currentOfficeId == officeId())
            || (officeName() != null && data.currentOfficeName != null && data.currentOfficeName == officeName())
            || (mapValueOrNull(data, "pendingTransfer") is map && officeId() != null && mapValueOrNull(data, "pendingTransfer").toOfficeId == officeId())
            || (mapValueOrNull(data, "pendingTransfer") is map && officeName() != null && mapValueOrNull(data, "pendingTransfer").toOfficeName != null && mapValueOrNull(data, "pendingTransfer").toOfficeName == officeName())
            || (mapValueOrNull(data, "pendingTransfer") is map && mapValueOrNull(data, "pendingTransfer").toUid != null && mapValueOrNull(data, "pendingTransfer").toUid == request.auth.uid)
            || (data.currentCustodianUid != null && data.currentCustodianUid == request.auth.uid)
          )
        );
    }

    function dtsCanRead(data) {
      return signedInUser() && (
        isSuperAdmin()
        || dtsOfficeAllowed(data)
      );
    }

    function dtsQrDoc(qrCode) {
      return get(/databases/$(database)/documents/dts_qr_codes/$(qrCode));
    }

    function dtsDocById(docId) {
      return get(/databases/$(database)/documents/dts_documents/$(docId));
    }

    function isPublishedStatus(statusValue) {
      return statusValue in ["published", "Published", "PUBLISHED"];
    }

    function systemSettingsPath() {
      return /databases/$(database)/documents/system/settings;
    }

    function systemSettingsExists() {
      return exists(systemSettingsPath());
    }

    function systemSettingsData() {
      return systemSettingsExists() ? get(systemSettingsPath()).data : null;
    }

    function featureEnabled(featureKey) {
      return !systemSettingsExists()
        || !(systemSettingsData().features is map)
        || !(featureKey in systemSettingsData().features)
        || systemSettingsData().features[featureKey] == true;
    }

    function systemReadOnly() {
      return systemSettingsExists()
        && systemSettingsData().readOnly == true;
    }

    function canWriteFeatureData() {
      return !systemReadOnly();
    }

    function postFeatureEnabled(data) {
      return data.type == "news"
        ? featureEnabled("news")
        : (
          data.type == "announcement"
            ? featureEnabled("announcements")
            : (featureEnabled("announcements") || featureEnabled("news"))
        );
    }

    /** -------------------------
     * USERS
     * /users/{uid}
     * ------------------------- */
    match /users/{uid} {
      allow create: if isOwner(uid)
        && mapValueOrNull(request.resource.data, "uid") == request.auth.uid
        && mapValueOrNull(request.resource.data, "role") == "resident"
        && mapValueOrNull(request.resource.data, "officeId") == null
        && mapValueOrNull(request.resource.data, "officeName") == null
        && (mapValueOrNull(request.resource.data, "isActive") == null || mapValueOrNull(request.resource.data, "isActive") == true);

      allow read: if signedInUser() && isOwner(uid);
      allow read: if signedInUser() && isSuperAdmin();
      allow read: if signedInUser() && isMunicipalAdmin();
      allow read: if signedInUser()
        && isOfficeAdmin()
        && officeId() != null
        && resource.data.officeId == officeId()
        && resource.data.role in ["resident", "moderator", "admin", "office_admin"];

      allow update: if activeUser() && (
        (
          isOwner(uid)
          && hasNoPrivilegedUserFieldChanges()
          && isAllowedUserSelfUpdate()
        )
        || (
          isSuperAdmin()
          && (
            mapValueOrNull(resource.data, "role") != "super_admin"
            || mapValueOrNull(request.resource.data, "role") == "super_admin"
          )
          && (
            mapValueOrNull(request.resource.data, "role") in ["office_admin", "moderator"]
              ? (
                mapValueOrNull(request.resource.data, "officeId") != null
                && mapValueOrNull(request.resource.data, "officeId") != ""
              )
              : true
          )
        )
      );

      allow delete: if activeUser() && isSuperAdmin();

      match /fcmTokens/{token} {
        allow read, write: if signedInUser() && isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read: if signedInUser() && isOwner(uid);
        allow update, delete: if signedInUser() && isOwner(uid);
        allow create: if false;
      }

      match /announcementReads/{announcementId} {
        allow read, write: if signedInUser() && isOwner(uid);
      }
    }

    /** -------------------------
     * SYSTEM SETTINGS
     * /system/settings
     * ------------------------- */
    match /system/{docId} {
      allow read: if docId == "settings";
      allow write: if docId == "settings" && activeUser() && isSuperAdmin();
    }

    /** -------------------------
     * AUDIT LOGS
     * /audit_logs/{id}
     * ------------------------- */
    match /audit_logs/{id} {
      allow read: if signedInUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
      );
      allow write: if false;
    }

    match /auditLogs/{id} {
      allow read: if signedInUser() && isSuperAdmin();
      allow write: if false;
    }

    /** -------------------------
     * REPORTS
     * /reports/{reportId}
     * ------------------------- */

    match /stats/{docId} {
      allow read: if signedInUser() && isStaff() && featureEnabled("reports");
      allow write: if false;
    }

    match /stats/daily/{dayId} {
      allow read: if signedInUser() && isStaff() && featureEnabled("reports");
      allow write: if false;
    }

    match /stats/assignees/{uid} {
      allow read: if signedInUser()
        && isStaff()
        && featureEnabled("reports")
        && (isSuperAdmin() || request.auth.uid == uid);
      allow write: if false;
    }

    match /reports/{reportId} {
      // TODO: Backfill report.officeId for stricter office scoping.
      // Public web and app intake should go through HTTP functions so validation,
      // rate limits, attachment checks, and duplicate detection cannot be bypassed.

      // Public intake must go through HTTP functions so validation, rate limits,
      // duplicate detection, and attachment checks cannot be bypassed client-side.
      allow create: if false;

      // Read:
      // - staff (moderator/office admin/super admin) can list and view reports
      // - residents can only read their own reports
      allow read: if signedInUser() && (
        reportStaffReadAllowed(resource.data)
        || resource.data.createdByUid == request.auth.uid
      );

      // Update:
      // - Resident can edit ONLY their own report content BEFORE it is handled
      //   and CANNOT change workflow fields (status/assignedToUid/createdByUid)
      // - Staff workflow updates are enforced through callable functions (server-side).
      allow update: if activeUser() && featureEnabled("reports") && canWriteFeatureData() && (
        (
          resource.data.createdByUid == request.auth.uid
          && (resource.data.status == "submitted" || resource.data.status == "in_review")
          && sameField("createdByUid")
          && sameField("assignedToUid")
          && sameField("assignedToName")
          && sameField("assignedOfficeId")
          && sameField("status")
          && unchangedOrWithin("title", 120)
          && unchangedOrWithin("description", 2000)
          && unchangedOrWithin("location", 120)
          && unchangedOrWithin("name", 80)
          && unchangedOrWithin("contact", 120)
          && !request.resource.data.diff(resource.data).changedKeys()
            .hasAny([
              "officeId",
              "assignedToName",
              "assignedOfficeId",
              "lastActionByUid",
              "lastActionByEmail",
              "lastActionByName",
              "lastActionByRole",
              "lastActionAt",
              "archived",
              "archivedAt",
              "archivedByUid",
              "archivedByEmail",
              "archivedByName",
              "archivedByRole"
            ])
        )
      );

      // Delete only super admin
      allow delete: if activeUser() && isSuperAdmin() && featureEnabled("reports") && canWriteFeatureData();

      // Optional: messages subcollection
      match /messages/{messageId} {
        allow read: if signedInUser()
          && (reportSubDocReadAllowed(resource.data) || reportSubDocLegacyStaffRead(resource.data));

        allow create: if activeUser() && featureEnabled("reports") && canWriteFeatureData() && (
          isSuperAdmin()
          || isMunicipalAdmin()
          || (isOfficeAdmin() && officeAllowed(get(/databases/$(database)/documents/reports/$(reportId)).data))
          || (
            isModerator()
            && get(/databases/$(database)/documents/reports/$(reportId)).data.assignedToUid == request.auth.uid
          )
        );

        allow update, delete: if false;
      }

      match /history/{historyId} {
        allow read: if signedInUser()
          && (reportSubDocReadAllowed(resource.data) || reportSubDocLegacyStaffRead(resource.data));
        allow write: if false;
      }

      match /timeline/{eventId} {
        // Timeline stays append-only and is written by backend code only.
        allow read: if signedInUser()
          && (reportSubDocReadAllowed(resource.data) || reportSubDocLegacyStaffRead(resource.data));
        allow write: if false;
      }
    }

    /** -------------------------
     * DTS DOCUMENTS
     * /dts_documents/{docId}
     * ------------------------- */
    match /dts_documents/{docId} {
      // Security hardening: DTS lifecycle mutations are callable-only.
      // Cloud Functions enforce role/scope, write shape, and audit timeline.
      allow create: if false;

      allow read: if featureEnabled("documentTracking") && dtsCanRead(resource.data);

      // All state mutations must run through callable functions (server-side checks).
      allow update: if false;

      allow delete: if activeUser() && isSuperAdmin() && featureEnabled("documentTracking") && canWriteFeatureData();

      match /timeline/{eventId} {
        allow read: if signedInUser() && isStaff() && featureEnabled("documentTracking");
        allow create, update, delete: if false;
      }
    }

    match /dts_qr_index/{qrCode} {
      allow read: if signedInUser() && isStaff() && featureEnabled("documentTracking");
      allow create: if false;
      allow update, delete: if false;
    }

    match /dts_qr_codes/{qrCode} {
      allow read: if signedInUser() && isStaff() && featureEnabled("documentTracking");
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    match /dts_counters/{year} {
      allow read: if signedInUser() && isStaff() && featureEnabled("documentTracking");
      allow create, update: if false;
      allow delete: if false;
    }

    /** -------------------------
     * ADVERTISEMENTS
     * /ads/{adId}
     * ------------------------- */
    match /ads/{adId} {
      allow read: if signedInUser() && (
        resource.data.status == "published"
        || isStaff()
      );

      allow create: if activeUser() && isStaff()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status in ["draft", "published"];

      allow update, delete: if activeUser() && isStaff();

      match /reactions/{uid} {
        allow read: if signedInUser() && (isOwner(uid) || isStaff());
        allow create, update: if signedInUser() && isOwner(uid)
          && request.resource.data.type in ["like", "dislike"];
        allow delete: if signedInUser() && isOwner(uid);
      }
    }

    /** -------------------------
     * ANNOUNCEMENTS
     * /announcements/{announcementId}
     * ------------------------- */
    match /announcements/{announcementId} {
      allow read: if (signedInUser() && isStaff())
        || (
          featureEnabled("announcements")
          && isPublishedStatus(resource.data.status)
        );

      allow create, update, delete: if false;

      match /views/{viewerUid} {
        allow read: if signedInUser() && (isOwner(viewerUid) || isSuperAdmin());
        allow create, update: if signedInUser() && request.auth.uid == viewerUid;
        allow delete: if false;
      }
    }

    /** -------------------------
     * POSTS
     * /posts/{postId}
     * ------------------------- */
    match /posts/{postId} {
      allow read: if (signedInUser() && isStaff())
        || (
          postFeatureEnabled(resource.data)
          && isPublishedStatus(resource.data.status)
        );

      // Privileged post mutations are callable-only so role/scope/audit checks
      // stay centralized in Cloud Functions.
      allow create, update, delete: if false;
    }

    /** -------------------------
     * PUBLIC DOCUMENTS
     * /public_docs/{docId}
     * ------------------------- */
    match /public_docs/{docId} {
      allow read: if (signedInUser() && isStaff())
        || (
          featureEnabled("transparency")
          && isPublishedStatus(resource.data.status)
        );

      // Privileged document mutations are callable-only so role/scope checks
      // cannot be bypassed through direct Firestore writes.
      allow create, update, delete: if false;
    }

    /** -------------------------
     * JOBS
     * /jobs/{jobId}
     * ------------------------- */
    match /jobs/{jobId} {
      allow read: if (signedInUser() && isStaff())
        || (
          featureEnabled("jobs")
          && isPublishedStatus(resource.data.status)
        );

      // Privileged job mutations are callable-only.
      allow create, update, delete: if false;
    }

    /** -------------------------
     * CIVIL REGISTRY REQUESTS
     * /civil_registry_requests/{requestId}
     * ------------------------- */
      match /civil_registry_requests/{requestId} {
        allow read: if canAccessCivilRegistry()
          && featureEnabled("civilRegistry");
        allow create, update, delete: if false;

        match /history/{historyId} {
          allow read: if canAccessCivilRegistry()
            && featureEnabled("civilRegistry");
          allow write: if false;
        }
      }

    match /civil_registry_counters/{year} {
      allow read, write: if false;
    }

    /** -------------------------
     * OFFICES
     * /offices/{officeId}
     * ------------------------- */
    match /offices/{officeId} {
      allow read: if signedInUser();
      allow create, update, delete: if activeUser() && isSuperAdmin();
    }

    /** -------------------------
     * APPOINTMENTS (Phase 2 prep)
     * /appointments/{appointmentId}
     * ------------------------- */
    match /appointments/{appointmentId} {
      allow read: if activeUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || ((isOfficeAdmin() || isModerator())
          && officeId() != null
          && resource.data.officeId == officeId())
      );
      allow create, update, delete: if activeUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || (isOfficeAdmin()
          && officeId() != null
          && request.resource.data.officeId == officeId())
      );
    }

    /** -------------------------
     * OFFICE SLOTS (Phase 2 prep)
     * /office_slots/{slotId}
     * ------------------------- */
    match /office_slots/{slotId} {
      allow read: if activeUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || ((isOfficeAdmin() || isModerator())
          && officeId() != null
          && resource.data.officeId == officeId())
      );
      allow create, update, delete: if activeUser() && (
        isSuperAdmin()
        || isMunicipalAdmin()
        || (isOfficeAdmin()
          && officeId() != null
          && request.resource.data.officeId == officeId())
      );
    }

    /** -------------------------
     * DIRECT STAFF MESSAGING
     * /staff_threads/{threadId}
     *
     * Realtime listeners are read-only from the client. All writes still go
     * through callable functions so server-side scope checks remain the source
     * of truth for staff messaging.
     * ------------------------- */
    match /staff_threads/{threadId} {
      allow read: if activeUser()
        && isStaff()
        && featureEnabled("messages")
        && resource.data.memberIds is list
        && resource.data.memberIds.hasAny([request.auth.uid]);
      allow create, update, delete: if false;

      match /messages/{messageId} {
        allow read: if activeUser()
          && isStaff()
          && featureEnabled("messages")
          && get(/databases/$(database)/documents/staff_threads/$(threadId)).data.memberIds is list
          && get(/databases/$(database)/documents/staff_threads/$(threadId)).data.memberIds.hasAny([request.auth.uid]);
        allow create, update, delete: if false;
      }
    }

    /** -------------------------
     * Default deny
     * ------------------------- */
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
